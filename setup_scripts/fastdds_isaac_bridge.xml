<?xml version="1.0" encoding="UTF-8" ?>
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

    <participant profile_name="ros_participant" is_default_profile="true">
        <rtps>
            <builtin>
                <!-- Tell FastDDS to unicast-probe the Windows host on startup.
                     No port = FastDDS tries participant IDs 0-3 automatically. -->
                <initialPeersList>
                    <locator>
                        <udpv4>
                            <address>192.168.65.1</address>
                        </udpv4>
                    </locator>
                </initialPeersList>
            </builtin>
        </rtps>
    </participant>

</profiles>
