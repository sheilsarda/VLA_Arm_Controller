<?xml version="1.0" encoding="UTF-8" ?>
<!--
  FastDDS profile for Isaac Sim (Windows side).
  Points discovery unicast at the ROS2 Docker container (192.168.65.6).
  Set FASTRTPS_DEFAULT_PROFILES_FILE to the path of this file before launching Isaac Sim.
-->
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

    <participant profile_name="isaac_sim_participant" is_default_profile="true">
        <rtps>
            <builtin>
                <initialPeersList>
                    <!-- ROS2 Docker container -->
                    <locator>
                        <udpv4>
                            <address>192.168.65.6</address>
                            <port>17910</port>
                        </udpv4>
                    </locator>
                    <locator>
                        <udpv4>
                            <address>192.168.65.6</address>
                            <port>17912</port>
                        </udpv4>
                    </locator>
                    <!-- Localhost (other Isaac Sim nodes) -->
                    <locator>
                        <udpv4>
                            <address>127.0.0.1</address>
                        </udpv4>
                    </locator>
                </initialPeersList>
            </builtin>
        </rtps>
    </participant>

</profiles>
